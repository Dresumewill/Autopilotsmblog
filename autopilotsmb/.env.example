# ─────────────────────────────────────────
# AutoPilotSMB — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────

# ── Database ──────────────────────────────
# PostgreSQL connection string
# For local: postgresql://user:password@localhost:5432/autopilotsmb
# For Supabase/Neon: copy from their dashboard
DATABASE_URL="postgresql://user:password@localhost:5432/autopilotsmb"

# ── NextAuth / Auth.js ────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# App URL (no trailing slash)
# Local: http://localhost:3000
# Prod:  https://autopilotsmb.com
NEXTAUTH_URL="http://localhost:3000"

# ── Stripe ────────────────────────────────
# From Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# From Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Site Configuration ────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="AutoPilotSMB"
NEXT_PUBLIC_SITE_DESCRIPTION="AI Tools & Automation for Small Businesses"

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Google AdSense (optional)
NEXT_PUBLIC_ADSENSE_ID="ca-pub-XXXXXXXXXXXXXXXXX"

# ── Admin ─────────────────────────────────
# Email of the initial admin account
ADMIN_EMAIL="admin@autopilotsmb.com"
ADMIN_PASSWORD="change-this-in-production"

# ── Email (optional — for newsletter) ─────
# Use Resend, Postmark, SendGrid, etc.
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="your-api-key"
EMAIL_FROM="hello@autopilotsmb.com"
